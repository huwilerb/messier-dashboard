# Application
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
DEBUG=false

# Base de donnees
DATABASE_URL=sqlite:///data/messier.db

# Upload
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=10

# Comportement
UNIQUE_OBSERVATION_PER_OBJECT=true

# bcrypt cost factor. Lower (e.g. 10-11) only if login latency is a real
# problem on weak hardware; do not change without good reason.
BCRYPT_ROUNDS=12
